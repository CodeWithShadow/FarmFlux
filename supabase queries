-- Upload: scoped to user's own folder (userId/filename)
CREATE POLICY "storage_upload_own" ON storage.objects
    FOR INSERT WITH CHECK (
        bucket_id = 'crop-images'
        AND auth.uid()::text = (storage.foldername(name))[1]
    );

-- Read: public access
CREATE POLICY "storage_read_all" ON storage.objects
    FOR SELECT USING (bucket_id = 'crop-images');

-- Delete: own files only
CREATE POLICY "storage_delete_own" ON storage.objects
    FOR DELETE USING (
        bucket_id = 'crop-images'
        AND auth.uid()::text = (storage.foldername(name))[1]
    );
